{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["jest", "node"],
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "app.ts",
    "drivers/**/*.ts",
    "lib/**/*.ts",
    "jest.config.ts",
    "**/*.test.ts"
  ],
  "exclude": ["node_modules", ".homeybuild"]
}
